# Copy to `.env` and fill in.
# .env is gitignored; never commit real keys.

NIM_API_KEY=nvapi-your-key-here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=deepseek-ai/deepseek-v4-pro

# Optional: HuggingFace (for SWE-bench dataset + CodeRankEmbed download)
HF_TOKEN=

# Optional: cache root (defaults to ./data/nim_cache)
HYBRIDLOC_CACHE_DIR=
